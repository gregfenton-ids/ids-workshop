{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "module": "NodeNext",
    "types": ["node", "multer"],
    "rootDir": "../../",
    "moduleResolution": "nodenext",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es2021",
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts", "../../database/seeds/data/**/*.ts"],
  "exclude": [
    "out-tsc",
    "dist",
    "jest.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "../../libs/**"
  ],
  "references": [
    {
      "path": "../../libs/shared/data-models/tsconfig.lib.json"
    }
  ]
}
