{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [2, "always", ["doc", "chore", "feat", "fix", "minor", "refact", "tool", "ux"]],
    "subject-case": [2, "never", ["sentence-case", "start-case", "pascal-case", "upper-case"]],
    "body-max-line-length": [2, "always", 200]
  },
  "parserPreset": {
    "parserOpts": {
      "headerPattern": "^(?!(?:chore|feat|fix|refact|test|tool|ux): )(doc|minor|chore|feat|fix|refact|test|tool|ux)(?:\\(([A-Z][A-Z0-9]*-\\d+)\\))?: (.{10,})$",
      "headerCorrespondence": ["type", "jira", "subject"]
    }
  }
}
