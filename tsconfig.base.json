{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022", "esnext.disposable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@ids-ai-skeleton/source"],
    "paths": {
      "@ids/data-models": ["./libs/shared/data-models/src/index.ts"],
      "@ids/testing-helpers": ["./libs/shared/testing-helpers/src/index.ts"]
    }
  }
}
