{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "noEmit": true
  },
  "include": ["./**/*.ts", "../libs/**/*.ts"],
  "exclude": ["../libs/**/*.spec.ts"]
}
